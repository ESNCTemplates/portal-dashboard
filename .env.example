# Baserow source (SaaS or self-hosted). SaaS builders set BASEROW_HOST=https://api.baserow.io
BASEROW_HOST=https://api.baserow.io
# DB token, READ-ONLY, scoped to exactly the tables the portal reads
BASEROW_TOKEN=replace-me
# Single shared password for the cookie gate
ACCESS_PASSWORD=replace-me
# openssl rand -hex 32
SESSION_SECRET=replace-me
