# Copy to .env.local for local dev; set the same keys in Vercel project settings.

# Base URL of self-hosted Baserow (no trailing slash)
BASEROW_HOST=https://your-baserow-host.example.com

# READ-ONLY token, scoped to exactly table 5209 (SM_Meme_Library). Used by
# app/api/memes/route.js. Server-side only — never sent to the browser.
BASEROW_TOKEN=

# WRITE token, scoped read+update (no delete) to exactly table 5209. Separate
# from BASEROW_TOKEN on purpose — used only by app/api/action/route.js.
BASEROW_WRITE_TOKEN=

# Giphy API key (developers.giphy.com, free). Used by app/api/giphy/route.js.
GIPHY_API_KEY=

# Shared password users type to view the dashboard.
ACCESS_PASSWORD=

# Random value the auth cookie is checked against:  openssl rand -hex 32
SESSION_SECRET=
