# Copy to .env.local for local dev; set the same keys in Coolify env.

# Base URL of the Baserow instance (no trailing slash)
BASEROW_HOST=https://your-baserow-host

# Baserow API token — scoped READ-ONLY to exactly the demo DB (968).
# Server-side only; never sent to the browser.
BASEROW_TOKEN=

# Shared password users type to view the dashboard.
ACCESS_PASSWORD=

# Random value the auth cookie is checked against:  openssl rand -hex 32
SESSION_SECRET=
